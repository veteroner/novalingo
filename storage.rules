rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Hiçbir dosya varsayılan olarak erişilemez
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    // Profil avatarları
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024  // 2MB max
                   && request.resource.contentType.matches('image/.*');
    }
    
    // İçerik dosyaları (ses, resim) — sadece okunabilir
    match /content/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Sadece admin SDK ile yüklenir
    }
    
    // Lottie animasyon dosyaları — sadece okunabilir
    match /animations/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
