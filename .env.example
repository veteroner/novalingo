# ===== Environment =====
VITE_APP_ENV=development
VITE_BUNDLE_TTS_AUDIO=true
VITE_TTS_AUDIO_BASE_URL=https://novalingo-app-tts.web.app

# ===== Firebase Config =====
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=novalingo-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=novalingo-dev
VITE_FIREBASE_STORAGE_BUCKET=novalingo-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ===== Firebase Emulators =====
VITE_USE_EMULATORS=true

# ===== Sentry =====
VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ===== reCAPTCHA =====
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# ===== Feature Flags =====
VITE_FEATURE_PUSH_ENABLED=false

# ===== Open-ended Conversation =====
VITE_OPEN_ENDED_EVALUATOR=hybrid
