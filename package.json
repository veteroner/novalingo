{
  "name": "novalingo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NovaLingo - Çocuklar için eğlenceli İngilizce öğrenme uygulaması",
  "author": "NovaLingo Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm run validate:conversation-registry",
    "build": "tsc -b && vite build",
    "build:staging": "tsc -b && vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "pretest": "pnpm run validate:conversation-registry",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:conversation-registry": "vitest run src/features/learning/data/conversations/__tests__/validateConversationScenario.test.ts",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "tts:prepare": "node scripts/prepare-tts-hosting.mjs",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "cap:build:android": "VITE_BUNDLE_TTS_AUDIO=false vite build && cap sync android",
    "cap:build:ios": "VITE_BUNDLE_TTS_AUDIO=false vite build && cap sync ios",
    "cap:build:android:staging": "pnpm run build:staging && cap sync android",
    "cap:build:ios:staging": "pnpm run build:staging && cap sync ios",
    "smoke:cap:staging": "pnpm run build:staging && node scripts/verify-capacitor-staging-smoke.mjs",
    "android:device:staging": "node scripts/android-device-staging.mjs",
    "firebase:emulators": "FUNCTIONS_DISCOVERY_TIMEOUT=60 firebase emulators:start --only auth,firestore,functions,storage,hosting --import=./emulator-data --export-on-exit=./emulator-data",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage",
    "firebase:deploy:functions": "firebase deploy --only functions",
    "firebase:deploy:functions:staging": "firebase deploy --only functions --project staging",
    "firebase:deploy:functions:prod": "firebase deploy --only functions --project production",
    "firebase:deploy:hosting": "firebase deploy --only hosting",
    "firebase:deploy:hosting:staging": "firebase deploy --only hosting --project staging",
    "firebase:deploy:hosting:prod": "firebase deploy --only hosting --project production",
    "firebase:deploy:tts:staging": "pnpm run tts:prepare && firebase deploy --only hosting:tts --project staging",
    "firebase:deploy:tts:prod": "pnpm run tts:prepare && firebase deploy --only hosting:tts --project production",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-community/in-app-review": "6.0.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@phosphor-icons/react": "^2.1.0",
    "@sentry/react": "^8.0.0",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.0",
    "cordova-plugin-purchase": "^13.13.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "firebase": "^11.2.0",
    "framer-motion": "^12.0.0",
    "howler": "^2.2.4",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lottie-react": "^2.4.0",
    "nanoid": "^5.0.0",
    "phonemizer": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.2.0",
    "react-router-dom": "^7.1.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/howler": "^2.2.12",
    "@types/node": ">=20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.8.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "storybook": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
