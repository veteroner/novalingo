rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== HELPER FUNCTIONS =====
    
    // Giriş yapmış mı?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Kullanıcı kendi verisine mi erişiyor?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Admin mi?
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    // Veri boyutu kontrolü
    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    function isValidAgeGroup(value) {
      return value == 'cubs' || value == 'stars' || value == 'legends';
    }

    function isValidLeagueTier(value) {
      return value == 'bronze'
        || value == 'silver'
        || value == 'gold'
        || value == 'platinum'
        || value == 'diamond'
        || value == 'legend';
    }

    function isValidChildCreate(data) {
      return data.keys().hasOnly([
          'parentUid',
          'name',
          'ageGroup',
          'avatarId',
          'level',
          'totalXP',
          'currentLevelXP',
          'nextLevelXP',
          'stars',
          'gems',
          'currentStreak',
          'longestStreak',
          'lastActivityDate',
          'streakFreezes',
          'novaStage',
          'novaHappiness',
          'novaOutfitId',
          'leagueId',
          'leagueTier',
          'weeklyXP',
          'currentWorldId',
          'currentUnitId',
          'completedLessons',
          'totalPlayTimeMinutes',
          'wordsLearned',
          'onboardingCompleted',
          'createdAt',
          'updatedAt'
        ])
        && data.parentUid == request.auth.uid
        && isValidString(data.name, 20)
        && data.name.size() >= 2
        && isValidAgeGroup(data.ageGroup)
        && isValidString(data.avatarId, 50)
        && data.level is int && data.level >= 1
        && data.totalXP is int && data.totalXP >= 0
        && data.currentLevelXP is int && data.currentLevelXP >= 0
        && data.nextLevelXP is int && data.nextLevelXP >= 0
        && data.stars is int && data.stars >= 0
        && data.gems is int && data.gems >= 0
        && data.currentStreak is int && data.currentStreak >= 0
        && data.longestStreak is int && data.longestStreak >= 0
        && data.lastActivityDate is string
        && data.streakFreezes is int && data.streakFreezes >= 0
        && isValidString(data.novaStage, 20)
        && data.novaHappiness is int && data.novaHappiness >= 0 && data.novaHappiness <= 100
        && (data.novaOutfitId == null || isValidString(data.novaOutfitId, 50))
        && isValidString(data.leagueId, 50)
        && isValidLeagueTier(data.leagueTier)
        && data.weeklyXP is int && data.weeklyXP >= 0
        && isValidString(data.currentWorldId, 50)
        && isValidString(data.currentUnitId, 50)
        && data.completedLessons is int && data.completedLessons >= 0
        && data.totalPlayTimeMinutes is int && data.totalPlayTimeMinutes >= 0
        && data.wordsLearned is int && data.wordsLearned >= 0
        && data.onboardingCompleted is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidChildUpdate() {
      let d = request.resource.data;
      let old = resource.data;
      return d.parentUid == old.parentUid
        && d.ageGroup == old.ageGroup
        && d.createdAt == old.createdAt
        && d.level is int && d.level >= 1 && d.level <= 100
        && d.totalXP is int && d.totalXP >= 0
        && d.currentLevelXP is int && d.currentLevelXP >= 0
        && d.nextLevelXP is int && d.nextLevelXP >= 0
        && d.stars is int && d.stars >= 0
        && d.gems is int && d.gems >= 0
        && d.currentStreak is int && d.currentStreak >= 0
        && d.longestStreak is int && d.longestStreak >= 0
        && d.streakFreezes is int && d.streakFreezes >= 0
        && d.completedLessons is int && d.completedLessons >= 0
        && d.totalPlayTimeMinutes is int && d.totalPlayTimeMinutes >= 0
        && d.wordsLearned is int && d.wordsLearned >= 0
        && d.updatedAt is timestamp;
    }

    // ===== USERS COLLECTION =====
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId); // COPPA: kullanıcı kendi hesabını silebilir

      // Purchase records
      match /purchases/{purchaseId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ===== CHILDREN COLLECTION (top-level) =====
    // Cloud Functions creates children with parentUid field.
    // Client can read/update own children.
    match /children/{childId} {
      allow read: if isAuthenticated() && resource.data.parentUid == request.auth.uid;
      allow create: if isAuthenticated() && isValidChildCreate(request.resource.data);
      allow update: if isAuthenticated()
        && resource.data.parentUid == request.auth.uid
        && isValidChildUpdate();
      allow delete: if isAuthenticated() && resource.data.parentUid == request.auth.uid;

      // Alt koleksiyonlar — client-side yazım (Spark plan uyumlu)
      match /lessonProgress/{lessonId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      match /vocabulary/{vocabId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      match /quests/{questId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      match /achievements/{achievementId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      match /inventory/{itemId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      // Günlük çark
      match /dailySpins/{dateId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      // İstatistikler (günlük/haftalık/aylık)
      match /stats/{period} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      // Konuşma oturum kayıtları
      match /conversationSessions/{sessionId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }

      // Konuşma senaryo en iyi skorları
      match /conversationBestScores/{scenarioId} {
        allow read, write: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      }
    }

    // ===== PROGRESS COLLECTION =====
    // Alternately structured progress data (per-child subcollections)
    match /progress/{childId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      allow write: if false;

      match /lessons/{lessonId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if false;
      }

      match /vocabulary/{wordId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if false;
      }

      match /stats/{period} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if false;
      }
    }

    // ===== GAMIFICATION COLLECTION =====
    match /gamification/{childId} {
      allow read: if isAuthenticated()
        && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
      allow write: if false; // Sadece Cloud Functions

      match /achievements/{achievementId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if false;
      }

      match /quests/{questId} {
        allow read: if isAuthenticated()
          && get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid;
        allow write: if false;
      }
    }

    // ===== LEADERBOARDS COLLECTION =====
    match /leaderboards/{leagueId} {
      allow read: if isAuthenticated();
      allow write: if false;
      
      match /entries/{entryId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated(); // Client leaderboard güncellemesi
      }
    }

    // ===== CONTENT COLLECTIONS (Read-only) =====
    match /worlds/{worldId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      match /units/{unitId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        
        match /lessons/{lessonId} {
          allow read: if isAuthenticated();
          allow write: if isAdmin();
        }
      }
    }

    // ===== SHOP ITEMS =====
    match /shopItems/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== ACHIEVEMENTS CATALOG =====
    match /achievementsCatalog/{achievementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== COLLECTIBLES =====
    match /collectibles/{collectibleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== DAILY WHEEL CONFIG =====
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ===== ANALYTICS (server-side only) =====
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Sadece Cloud Functions
    }

    // ===== RATE LIMITS (server-side only) =====
    match /rateLimits/{docId} {
      allow read, write: if false; // Sadece Cloud Functions
    }

    // ===== CATCH-ALL: Deny everything else =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
